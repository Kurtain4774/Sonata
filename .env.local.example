# Spotify — create an app at https://developer.spotify.com/dashboard
# Add redirect URI: http://127.0.0.1:3000/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# NextAuth
NEXTAUTH_URL=http://127.0.0.1:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Encryption key for Spotify tokens stored in MongoDB (32 bytes, base64)
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Gemini — get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# MongoDB — local mongod or an Atlas connection string
MONGODB_URI=
